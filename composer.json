{
    "name": "schmeits/sentry-noise-filter",
    "description": "Drop-in Sentry/GlitchTip noise filter for Laravel. Install, set DSN, done.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Tally Schmeits",
            "email": "tally@schmeits.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "sentry/sentry-laravel": "^4.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Schmeits\\SentryNoiseFilter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Schmeits\\SentryNoiseFilter\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Schmeits\\SentryNoiseFilter\\SentryNoiseFilterServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable"
}
